# MediQuery AI - Environment Configuration

# ============================================================================
# AWS Configuration
# ============================================================================
AWS_REGION=us-east-1
AWS_PROFILE=default
S3_BUCKET=mediquery-documents

# OpenSearch Configuration
OPENSEARCH_ENDPOINT=https://your-domain.us-east-1.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=Admin123!

BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Anthropic Direct API (TEMPORARY - while AWS Marketplace subscription pending)
# WARNING: Bypasses Bedrock security. Use only for demo/development.
USE_DIRECT_ANTHROPIC=false
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# Debug Configuration
# ============================================================================
DEBUG_MODE=true
LOG_LEVEL=DEBUG
LOG_FORMAT=console
LOG_TO_FILE=true

# Agent Tracing
TRACE_AGENTS=true
TRACE_AGENT_INPUTS=true
TRACE_AGENT_OUTPUTS=true
TRACE_AGENT_TIMING=true

# LLM Tracing
TRACE_LLM_CALLS=true
TRACE_LLM_PROMPTS=true
TRACE_LLM_RESPONSES=true
TRACE_LLM_TOKENS=true
TRACE_LLM_COST=true

# Performance
SLOW_QUERY_THRESHOLD_MS=3000
SLOW_AGENT_THRESHOLD_MS=1000

# ============================================================================
# Application Configuration
# ============================================================================
APP_NAME=MediQuery AI
APP_VERSION=1.0.0
MAX_FILE_SIZE=52428800

# ============================================================================
# Vector Search
# ============================================================================
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSION=1024
TOP_K_RETRIEVAL=20
TOP_K_RERANK=5
